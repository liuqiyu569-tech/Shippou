# ============================================================
# 容器化环境变量模板
# 用法：cp .env.example .env  然后填入真实值。.env 已在 .gitignore，不会入库
# ============================================================

# ---- MySQL ----
# root 密码：mysql 容器用它建库 + app 容器也用它连库（sharding-config 里 username=root）
MYSQL_ROOT_PASSWORD=changeme_root_pw
MYSQL_DATABASE=short_url

# ---- RabbitMQ ----
RABBITMQ_USERNAME=admin
RABBITMQ_PASSWORD=changeme_mq_pw

# ---- 应用 ----
# 暴露给外部的短链域名（部署到 ECS 后改成 http://<ECS公网IP>:8080 或正式域名）
SHORTURL_DOMAIN=http://localhost:8080

# ---- 可选：上云开了 Redis 密码再启用 ----
# SPRING_DATA_REDIS_PASSWORD=your_redis_pw
