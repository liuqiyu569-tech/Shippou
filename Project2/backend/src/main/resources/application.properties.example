server.port=8080

# 数据源配置（复制此文件为 application.properties，填入你本地的数据库信息）
spring.datasource.url=jdbc:mysql://127.0.0.1:3306/task_management?characterEncoding=utf-8&serverTimezone=Asia/Shanghai
spring.datasource.username=root
spring.datasource.password=your_password_here

# MyBatis 配置
mybatis.mapper-locations=classpath:mapper/*.xml
mybatis.type-aliases-package=com.taskmanagement.entity
mybatis.configuration.map-underscore-to-camel-case=true

# Jackson 序列化配置
spring.jackson.time-zone=Asia/Shanghai

# JWT 配置（请使用至少 64 字符的随机字符串）
app.jwt.secret=please-replace-with-a-secure-random-secret-at-least-64-chars-long
app.jwt.expiration-ms=86400000

# CORS 配置
app.cors.allowed-origins=http://localhost:5173
